{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Sparkle",
  "colors": {
    "primary": "#0000ff",
    "light": "#58beff",
    "dark": "#0000ff"
  },
  "favicon": {
    "light": "/favicon/light.svg",
    "dark": "/favicon/dark.svg"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/get-started/welcome"
    },
    {
      "source": "/quickstart",
      "destination": "/get-started/quickstart"
    }
  ],
  "navigation": {
    "pages": [
      {
        "group": "Get Started",
        "pages": [
          "get-started/welcome",
          "get-started/quickstart"
        ]
      },
      {
        "group": "Extension",
        "pages": [
          "extension/cursor",
          "extension/windsurf",
          "extension/usage",
          "extension/troubleshooting"
        ]
      },
      {
        "group": "CLI",
        "pages": [
          "cli/install",
          "cli/usage",
          "cli/commands"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/configuration",
          "reference/changelog"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
